    TRUE            reduce using rule 5 (Stmt -> LET ID : Type = E ; .)
    FALSE           reduce using rule 5 (Stmt -> LET ID : Type = E ; .)
    ID              reduce using rule 5 (Stmt -> LET ID : Type = E ; .)
    $end            reduce using rule 5 (Stmt -> LET ID : Type = E ; .)

